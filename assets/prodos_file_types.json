  "_extensions_comment": "Host-filename extension → ProDOS (type_byte, aux_type) mapping. Used when adding a file to a ProDOS image if the user did not specify an explicit type. Aux types are ProDOS conventions: $0801 for Applesoft BASIC, $2000 for typical BIN load address, $0000 otherwise.",
  "extensions": {
    "txt":   { "type": "$04", "aux_type": "$0000" },
    "text":  { "type": "$04", "aux_type": "$0000" },
    "asc":   { "type": "$04", "aux_type": "$0000" },
    "md":    { "type": "$04", "aux_type": "$0000" },
