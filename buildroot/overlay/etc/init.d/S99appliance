#!/bin/sh
# rusty-backup appliance — boot banner + disk summary.
# Drops to a root shell with rb-cli in PATH (backup AND restore).

case "$1" in
  start)
    clear 2>/dev/null
    cat <<'BANNER'

  ====================================================
   rusty-backup appliance  (rb-cli)
   backup + restore for vintage disks, from the metal
  ====================================================

BANNER
    echo " Detected block devices:"
    # /sys/block lists hda, sda, etc.; show size in MiB.
    for d in /sys/block/*; do
      [ -e "$d/size" ] || continue
      name=$(basename "$d")
      case "$name" in loop*|ram*) continue ;; esac
      sectors=$(cat "$d/size")
      mib=$(( sectors / 2048 ))
      echo "   /dev/$name   ${mib} MiB"
    done
    echo
    echo " Quick start:"
    echo "   rb-cli inspect /dev/hda            # show the partition layout"
    echo "   rb-cli backup  /dev/hda /mnt/bkp   # back up a disk"
    echo "   rb-cli restore /mnt/bkp  /dev/hda  # restore a disk"
    echo "   rb-cli --help                      # all verbs"
    echo
    echo " (mount your destination on /mnt first, e.g. a 2nd disk or USB.)"
    echo
    ;;
  stop) : ;;
esac
exit 0
