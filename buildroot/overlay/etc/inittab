# /etc/inittab — rusty-backup appliance
#
# Boots straight into the rb-cli backup/restore menu (installer-CD style) on
# BOTH the VGA console (tty1, for a real monitor) and the serial port (ttyS0,
# for a headless serial terminal / qemu verification). Running the menu on two
# explicit lines — instead of on the single /dev/console getty Buildroot
# generates — is what lets a real-hardware user and a headless/CI user each see
# and drive the menu regardless of which console= the kernel made primary.
# When the menu quits it drops to a shell on that line; init respawns the getty.
#
# This file is applied via the rootfs overlay, which Buildroot copies AFTER its
# own getty/inittab fixups, so it is the authoritative inittab.
#
# BusyBox init ignores runlevels. Format: <id>:<runlevels>:<action>:<process>

# Startup
::sysinit:/bin/mount -t proc proc /proc
::sysinit:/bin/mount -o remount,rw /
::sysinit:/bin/mkdir -p /dev/pts /dev/shm
::sysinit:/bin/mount -a
::sysinit:/bin/mkdir -p /run/lock/subsys
::sysinit:/sbin/swapon -a
null::sysinit:/bin/ln -sf /proc/self/fd /dev/fd
null::sysinit:/bin/ln -sf /proc/self/fd/0 /dev/stdin
null::sysinit:/bin/ln -sf /proc/self/fd/1 /dev/stdout
null::sysinit:/bin/ln -sf /proc/self/fd/2 /dev/stderr
::sysinit:/bin/hostname -F /etc/hostname
::sysinit:/etc/init.d/rcS

# Appliance menu: VGA monitor (tty1) and serial line (ttyS0, 115200 8N1).
tty1::respawn:/sbin/getty -L -n -l /usr/bin/appliance-menu tty1 0 vt100
ttyS0::respawn:/sbin/getty -L -n -l /usr/bin/appliance-menu ttyS0 115200 vt100

# Shutdown
::shutdown:/etc/init.d/rcK
::shutdown:/sbin/swapoff -a
::shutdown:/bin/umount -a -r
::ctrlaltdel:/sbin/reboot
